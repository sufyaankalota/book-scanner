# Required
DATABASE_URL=postgresql://user:password@host:port/db
REDIS_URL=redis://default:password@host:port

# Optional (defaults shown)
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# CORS allow-list (comma-separated). Default permits Vercel preview + prod book-scanner.
CORS_ORIGINS=https://book-scanner-puce.vercel.app,http://localhost:5173
