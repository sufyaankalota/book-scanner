rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Jobs — anyone can read (pods, dashboard, portal all need it)
    // Only authenticated sessions can create/update; delete restricted
    match /jobs/{jobId} {
      allow read: if true;
      allow create, update, delete: if true;

      // Manifest subcollection — read/write for PO lookups & uploads
      match /manifest/{isbn} {
        allow read, write: if true;
      }

      // Chunked manifest storage (used for large manifests)
      match /manifest-chunks/{chunkId} {
        allow read, write: if true;
      }
    }

    // Scans — pods write, dashboard/portal read
    match /scans/{scanId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['jobId', 'podId', 'isbn', 'type'])
        && request.resource.data.jobId is string
        && request.resource.data.podId is string
        && request.resource.data.isbn is string
        && request.resource.data.type in ['standard', 'exception']
        && request.resource.data.isbn.size() >= 8
        && request.resource.data.isbn.size() <= 18;
      allow update: if false;
      allow delete: if true;
    }

    // Exceptions — pods write, dashboard/portal read
    match /exceptions/{exId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['jobId', 'podId', 'reason']);
      allow update: if true;
      allow delete: if true;
    }

    // Shifts — pods write, dashboard reads
    match /shifts/{shiftId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['jobId', 'podId'])
        && request.resource.data.operatorName is string;
      allow update: if true;
      allow delete: if false; // Shift records are immutable
    }

    // BOLs — portal uploads, dashboard manages
    match /bols/{bolId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['jobId', 'date', 'fileName']);
      allow update, delete: if true;
    }

    // Presence — pods heartbeat
    match /presence/{podId} {
      allow read: if true;
      allow write: if true;
    }

    // Config — supervisor PIN, branding, alerts, customer password, schedule
    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }

    // Photo uploads — temporary docs for phone-to-pod photo transfer
    match /photo-uploads/{tokenId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['photo', 'timestamp']);
      allow delete: if true;
      allow update: if false;
    }

    // Audit log — internal logging (immutable)
    match /audit/{logId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['action', 'timestamp']);
      allow update, delete: if false; // Audit trail is immutable
    }

    // Billing reports — dashboard creates, portal reads, archive/delete supported
    match /billing-reports/{reportId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['jobId', 'weekStart', 'weekEnd', 'fileName']);
      allow update: if true;
      allow delete: if true;
    }

    // PO uploads — customer uploads, dashboard/setup reads and attaches to jobs
    match /po-uploads/{uploadId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['poNames', 'isbnCount', 'uploadedAt', 'status']);
      allow update, delete: if true;

      match /manifest/{isbn} {
        allow read, write: if true;
      }

      // Chunked manifest storage (used for uploads > a few thousand ISBNs)
      match /manifest-chunks/{chunkId} {
        allow read, write: if true;
      }
    }

    // Users — app user management
    match /users/{userId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'passwordHash', 'role']);
      allow update, delete: if true;
    }

    // Daily summaries — dashboard creates, portal reads
    match /daily-summaries/{summaryId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['jobId', 'date', 'totalScans']);
      allow update, delete: if false;
    }

    // AI usage telemetry — written by Cloud Function, read by Dashboard for cost reporting
    match /ai-usage/{usageId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
